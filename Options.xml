<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\..\FrameXML\UI.xsd">

	<Frame name="ArcHUDOptionsFrame" parent="UIParent" toplevel="true" hidden="true" frameStrata="DIALOG" enableMouse="true" movable="true">
		<Size>
			<AbsDimension x="620" y="480"/>
		</Size>
		<Anchors>
			<Anchor point="CENTER"/>
		</Anchors>
		<Backdrop bgFile="Interface\DialogFrame\UI-DialogBox-Background" edgeFile="Interface\DialogFrame\UI-DialogBox-Border" tile="true">
			<BackgroundInsets>
				<AbsInset left="11" right="12" top="12" bottom="11"/>
			</BackgroundInsets>
			<TileSize val="32"/>
			<EdgeSize val="32"/>
		</Backdrop>
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentTitle" inherits="GameFontHighlight" text="Teron's ArcHUD">
					<Anchors>
						<Anchor point="TOP">
							<Offset>
								<AbsDimension x="0" y="-16"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
				<FontString name="$parentContentTitle" inherits="GameFontNormalLarge" justifyH="LEFT">
					<Anchors>
						<Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
							<Offset>
								<AbsDimension x="212" y="-40"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Button name="$parentCloseButton" inherits="UIPanelCloseButton">
				<Anchors>
					<Anchor point="TOPRIGHT">
						<Offset>
							<AbsDimension x="-4" y="-4"/>
						</Offset>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnClick>
						ArcHUD.Options:Hide()
					</OnClick>
				</Scripts>
			</Button>

			<!-- Left column: one button per settings category. UIPanelScrollFrameTemplate's
			     scrollbar sits ~20-25px outside the scrollframe's own right edge, so the
			     frame is sized wider than the buttons inside it to leave that clear. -->
			<ScrollFrame name="$parentCategoryScrollFrame" inherits="UIPanelScrollFrameTemplate">
				<Size>
					<AbsDimension x="170" y="370"/>
				</Size>
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset>
							<AbsDimension x="14" y="-58"/>
						</Offset>
					</Anchor>
				</Anchors>
				<ScrollChild>
					<Frame name="$parentScrollChild">
						<Size>
							<AbsDimension x="170" y="370"/>
						</Size>
						<Anchors>
							<Anchor point="TOPLEFT"/>
						</Anchors>
					</Frame>
				</ScrollChild>
			</ScrollFrame>

			<!-- Divider between the category list and the selected category's options -->
			<Frame name="$parentDivider">
				<Size>
					<AbsDimension x="1" y="370"/>
				</Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parentCategoryScrollFrame" relativePoint="TOPRIGHT">
						<Offset>
							<AbsDimension x="10" y="0"/>
						</Offset>
					</Anchor>
				</Anchors>
				<Layers>
					<Layer level="ARTWORK">
						<Texture setAllPoints="true">
							<Color r="1" g="1" b="1" a="0.2"/>
						</Texture>
					</Layer>
				</Layers>
			</Frame>

			<!-- Right column: the selected category's options. Same scrollbar-clearance
			     reasoning as the category list, plus room on top of that for the dialog's
			     own ~12px border texture along the frame's right edge - the scrollbar was
			     landing on top of the border itself before this was widened further. -->
			<ScrollFrame name="$parentContentScrollFrame" inherits="UIPanelScrollFrameTemplate">
				<Size>
					<AbsDimension x="360" y="346"/>
				</Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parentCategoryScrollFrame" relativePoint="TOPRIGHT">
						<Offset>
							<AbsDimension x="28" y="-22"/>
						</Offset>
					</Anchor>
				</Anchors>
				<ScrollChild>
					<Frame name="$parentScrollChild">
						<Size>
							<AbsDimension x="360" y="346"/>
						</Size>
						<Anchors>
							<Anchor point="TOPLEFT"/>
						</Anchors>
					</Frame>
				</ScrollChild>
			</ScrollFrame>
		</Frames>
		<Scripts>
			<OnLoad>
				this:RegisterForDrag("LeftButton")
			</OnLoad>
			<OnDragStart>
				this:StartMoving()
			</OnDragStart>
			<OnDragStop>
				this:StopMovingOrSizing()
			</OnDragStop>
			<OnShow>
				ArcHUD.Options:OnShow()
			</OnShow>
		</Scripts>
	</Frame>
</Ui>
